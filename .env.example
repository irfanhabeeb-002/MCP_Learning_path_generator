# Copy to .env and fill in your values (never commit .env)

# Gemini orchestration (Google AI Studio)
GOOGLE_API_KEY=your-google-ai-studio-api-key

# YouTube Data API v3 (used by the MCP server)
YOUTUBE_API_KEY=your-youtube-data-api-key

# Custom MCP server endpoint
MCP_SERVER_URL=http://127.0.0.1:8001/mcp

# Optional MCP server settings (when running mcp_server/server.py)
# MCP_HOST=127.0.0.1
# MCP_PORT=8001   # default; must match MCP_SERVER_URL port

# Max wall-clock seconds for one agent run (default 300)
# AGENT_TIMEOUT_SECONDS=300
# YOUTUBE_MAX_RESULTS=10
